---
// This page has moved to /catalogue/ — see SiteNav.astro and catalogue/index.astro.
import { withBase } from '../../lib/paths';
const url = withBase('/catalogue/');
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${url}`} />
    <title>Redirecting to catalogue…</title>
  </head>
  <body>
    <script define:vars={{ url }}>window.location.replace(url);</script>
    <p>This page has moved. <a href={url}>Go to the pack catalogue →</a></p>
  </body>
</html>
