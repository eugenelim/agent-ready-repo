---
// Footer — dark zone. Section 9 ("Build Your Org") closer is added in T6 above
// these links; for now this is the minimal footer (GitHub, PyPI, Docs).
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <p class="footer__brand">agent-ready-repo</p>
    <nav class="footer__links" aria-label="Footer">
      <a href="/docs/" rel="noopener">Docs</a>
      <a href="https://github.com/eugenelim/agent-ready-repo" rel="noopener">GitHub</a>
      <a href="https://pypi.org/project/agentbundle/" rel="noopener">PyPI</a>
    </nav>
    <p class="footer__copy">© {year} · The supervised AI operating model for software teams.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--ds-hero-bg);
    color: var(--ds-hero-fg-muted);
  }

  .footer__inner {
    max-width: var(--ds-content-max);
    margin-inline: auto;
    padding: var(--ds-space-7) var(--ds-content-pad-x);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--ds-space-4) var(--ds-space-6);
  }

  .footer__brand {
    font-family: var(--ds-font-mono);
    font-weight: var(--ds-weight-bold);
    color: var(--ds-hero-fg);
  }

  .footer__links {
    display: flex;
    gap: var(--ds-space-5);
  }

  .footer__links a {
    color: var(--ds-hero-fg-2);
    font-size: var(--ds-type-sm);
  }

  .footer__links a:hover {
    color: var(--ds-accent);
    text-decoration: none;
  }

  .footer__copy {
    flex-basis: 100%;
    font-size: var(--ds-type-sm);
    color: var(--ds-hero-fg-muted);
  }
</style>
