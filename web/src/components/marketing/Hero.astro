---
// Section 1 — HERO. Dark zone (--ds-hero-bg), full-bleed, continuous with the
// nav above and the stat strip below. Radial amber glow + faint grid texture
// (matching the MkDocs hero). One-shot 300ms opacity fade-in on load, guarded
// by prefers-reduced-motion. No looping animation (aesthetic-direction.md).
---

<section class="hero">
  <div class="hero__inner">
    <h1 class="hero__headline">The supervised AI operating model for software teams.</h1>
    <p class="hero__subhead">
      Three peer loops span the full SDLC. Hard mechanical gates, cold-read
      specialist reviewers, and human checkpoints at every handoff — so the agent
      can't certify its own work.
    </p>
    <div class="hero__actions">
      <a class="hero__cta hero__cta--primary" href="/#install">
        Install the core loop <span aria-hidden="true">→</span>
      </a>
      <a class="hero__cta hero__cta--ghost" href="/packs/">
        See the packs <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--ds-hero-bg);
    background-image:
      radial-gradient(ellipse 70% 60% at 50% 0%, var(--ds-accent-glow) 0%, transparent 65%),
      linear-gradient(var(--ds-hero-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--ds-hero-border) 1px, transparent 1px);
    background-size: 100% 100%, 28px 28px, 28px 28px;
    color: var(--ds-hero-fg);
  }

  .hero__inner {
    max-width: var(--ds-content-max);
    margin-inline: auto;
    padding: var(--ds-space-9) var(--ds-content-pad-x) var(--ds-space-8);
  }

  .hero__headline {
    color: var(--ds-hero-fg);
    max-width: 18ch;
    margin-bottom: var(--ds-space-5);
  }

  .hero__subhead {
    color: var(--ds-hero-fg-2);
    font-size: var(--ds-type-body-lg);
    max-width: 60ch;
    margin-bottom: var(--ds-space-6);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ds-space-3);
  }

  .hero__cta {
    display: inline-block;
    padding: 0.7rem 1.6rem;
    border-radius: var(--ds-radius-pill);
    font-weight: var(--ds-weight-semibold);
    font-size: var(--ds-type-body);
    border: 1px solid transparent;
  }

  .hero__cta:hover {
    text-decoration: none;
  }

  .hero__cta--primary {
    background-color: var(--ds-cta-primary-bg);
    color: var(--ds-cta-primary-fg);
    border-color: var(--ds-cta-primary-bg);
  }

  .hero__cta--primary:hover {
    background-color: var(--ds-cta-primary-bg-hover);
    border-color: var(--ds-cta-primary-bg-hover);
  }

  .hero__cta--ghost {
    background-color: transparent;
    color: var(--ds-cta-ghost-fg);
    border-color: var(--ds-cta-ghost-border);
  }

  .hero__cta--ghost:hover {
    background-color: var(--ds-cta-ghost-bg-hover);
    color: var(--ds-hero-fg);
  }

  /* One-shot fade-in on load — 300ms, guarded. Static by default for
     reduced-motion (content is visible without the animation). */
  @media (prefers-reduced-motion: no-preference) {
    .hero__inner {
      animation: hero-fade var(--ds-dur-gentle) var(--ds-ease-out) both;
    }
  }

  @keyframes hero-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
