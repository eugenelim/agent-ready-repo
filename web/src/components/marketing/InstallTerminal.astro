---
// Section 7 — INSTALL. Light zone (surface-alt). CSS-only tabs via a radio
// group — zero JavaScript for tab switching, keyboard-navigable (arrow keys
// move between radios). Copy button uses a small JS snippet that reads the
// currently-checked radio to collect the active panel's commands.
import Section from '../layout/Section.astro';

const tabs = [
  { id: 'flagship', label: 'Flagship loop', lines: ['pip install agentbundle', 'agentbundle install --pack core'] },
  { id: 'discovery', label: 'With discovery', lines: ['agentbundle install --pack core', 'agentbundle install --pack product-engineering --scope user'] },
  { id: 'inception', label: 'Full inception', lines: ['agentbundle install --profile inception'] },
  { id: 'architect', label: 'Solution architect', lines: ['agentbundle install --profile solution-architect'] },
];
---

<Section tone="surface-alt" id="install" labelledby="install-heading">
  <h2 id="install-heading" class="install__headline">Start in one command.</h2>

  <div class="terminal">
    <div class="terminal__bar">
      <span class="terminal__dot" aria-hidden="true"></span>
      <span class="terminal__dot" aria-hidden="true"></span>
      <span class="terminal__dot" aria-hidden="true"></span>
      <button
        class="install-copy-btn"
        aria-label="Copy install commands"
        type="button"
      >
        <span class="install-copy-btn__icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="4" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
            <path d="M2 10V2.5A1.5 1.5 0 0 1 3.5 1H10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="install-copy-btn__label">Copy</span>
      </button>
    </div>

    <div class="tabs" role="group" aria-label="Install options">
      {tabs.map((t, i) => (
        <>
          <input
            class="tabs__radio"
            type="radio"
            name="install-tabs"
            id={`install-tab-${t.id}`}
            checked={i === 0}
          />
          <label class="tabs__label" for={`install-tab-${t.id}`}>{t.label}</label>
        </>
      ))}

      <div class="tabs__panels">
        {tabs.map((t) => (
          <div class={`tabs__panel tabs__panel--${t.id}`}>
            {t.lines.map((line) => (
              <div class="terminal__line">
                <span class="terminal__prompt" aria-hidden="true">❯ </span><code>{line}</code>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>

  <p class="install__note">
    One command lands the loop. Any agent that reads a skill file inherits it automatically.
  </p>
</Section>

<script>
  const copyBtn = document.querySelector<HTMLButtonElement>('.install-copy-btn');
  const label = copyBtn?.querySelector<HTMLElement>('.install-copy-btn__label');

  function getActiveCommands(): string {
    const checked = document.querySelector<HTMLInputElement>('.tabs__radio:checked');
    if (!checked) return '';
    const id = checked.id.replace('install-tab-', '');
    const panel = document.querySelector(`.tabs__panel--${id}`);
    if (!panel) return '';
    return Array.from(panel.querySelectorAll('code'))
      .map((c) => c.textContent ?? '')
      .join('\n');
  }

  copyBtn?.addEventListener('click', async () => {
    const cmd = getActiveCommands();
    try {
      await navigator.clipboard.writeText(cmd);
      if (label) {
        label.textContent = 'Copied!';
        copyBtn.classList.add('install-copy-btn--success');
        setTimeout(() => {
          label.textContent = 'Copy';
          copyBtn.classList.remove('install-copy-btn--success');
        }, 2000);
      }
    } catch {
      // Clipboard API unavailable — commands are still visible and selectable.
    }
  });
</script>

<style>
  .install__headline {
    margin-bottom: var(--ds-space-6);
  }

  .terminal {
    background-color: var(--ds-hero-bg);
    border: 1px solid var(--ds-hero-border-card);
    border-radius: var(--ds-radius-lg);
    overflow: hidden;
    max-width: 760px;
  }

  .terminal__bar {
    display: flex;
    align-items: center;
    gap: var(--ds-space-2);
    padding: var(--ds-space-3) var(--ds-space-4);
    border-bottom: 1px solid var(--ds-hero-border);
  }

  .terminal__dot {
    width: 11px;
    height: 11px;
    border-radius: var(--ds-radius-pill);
    background-color: var(--ds-hero-border-card);
  }

  /* Copy button sits at the right end of the terminal bar. */
  .install-copy-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--ds-space-1);
    margin-left: auto;
    background-color: var(--ds-hero-elevated);
    border: 1px solid var(--ds-hero-border-card);
    border-radius: var(--ds-radius-sm);
    color: var(--ds-hero-fg-muted);
    font-family: var(--ds-font-mono);
    font-size: var(--ds-type-xs);
    font-weight: var(--ds-weight-medium);
    padding: 0.3rem 0.6rem;
    cursor: pointer;
    transition:
      background-color var(--ds-dur-quick) var(--ds-ease-std),
      color var(--ds-dur-quick) var(--ds-ease-std),
      border-color var(--ds-dur-quick) var(--ds-ease-std);
  }

  .install-copy-btn:hover {
    background-color: var(--ds-accent-subtle-dk);
    border-color: var(--ds-accent);
    color: var(--ds-accent);
  }

  .install-copy-btn--success {
    background-color: var(--ds-accent-subtle-dk);
    border-color: var(--ds-accent);
    color: var(--ds-accent);
  }

  .install-copy-btn__icon {
    display: flex;
    align-items: center;
  }

  /* ── CSS-only tabs ─────────────────────────────────────────────────── */
  .tabs {
    display: flex;
    flex-wrap: wrap;
  }

  /* Radios stay in the tab order for keyboard use, but are visually hidden. */
  .tabs__radio {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }

  .tabs__label {
    padding: var(--ds-space-3) var(--ds-space-5);
    font-size: var(--ds-type-sm);
    font-weight: var(--ds-weight-medium);
    color: var(--ds-hero-fg-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    user-select: none;
  }

  .tabs__label:hover {
    color: var(--ds-hero-fg-2);
  }

  .tabs__panels {
    flex-basis: 100%;
    width: 100%;
    border-top: 1px solid var(--ds-hero-border);
  }

  .tabs__panel {
    display: none;
    padding: var(--ds-space-5) var(--ds-space-5) var(--ds-space-6);
    color: var(--ds-hero-fg);
    overflow-x: auto;
  }

  .terminal__line {
    white-space: nowrap;
    line-height: var(--ds-lead-mono);
  }

  .terminal__line code {
    color: var(--ds-hero-fg);
    background: none;
  }

  .terminal__prompt {
    color: var(--ds-accent);
    font-weight: var(--ds-weight-bold);
    font-family: var(--ds-font-mono);
  }

  /* Active tab label + its panel, driven by the checked radio. */
  #install-tab-flagship:checked ~ .tabs__panels .tabs__panel--flagship,
  #install-tab-discovery:checked ~ .tabs__panels .tabs__panel--discovery,
  #install-tab-inception:checked ~ .tabs__panels .tabs__panel--inception,
  #install-tab-architect:checked ~ .tabs__panels .tabs__panel--architect {
    display: block;
  }

  #install-tab-flagship:checked + .tabs__label,
  #install-tab-discovery:checked + .tabs__label,
  #install-tab-inception:checked + .tabs__label,
  #install-tab-architect:checked + .tabs__label {
    color: var(--ds-accent);
    border-bottom-color: var(--ds-accent);
  }

  /* Keyboard focus lands on the (hidden) radio — surface it on the label. */
  .tabs__radio:focus-visible + .tabs__label {
    outline: 2px solid var(--ds-accent);
    outline-offset: -2px;
  }

  .install__note {
    margin-top: var(--ds-space-5);
    color: var(--ds-on-surface-muted);
    max-width: 60ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .install-copy-btn {
      transition: none;
    }
  }
</style>
