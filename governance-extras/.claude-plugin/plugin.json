{
  "name": "governance-extras",
  "version": "0.8.2",
  "description": "Governance skills (new-rfc, new-adr, update-conventions, rfc-status) and RFC/ADR templates + seed READMEs.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
