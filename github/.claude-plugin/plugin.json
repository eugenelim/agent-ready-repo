{
  "name": "github",
  "version": "0.1.1",
  "description": "GitHub integration: `github-brief-intake` \u2014 turn a GitHub Milestone into a product brief and hand off to `receive-brief`.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/.claude-plugin/scripts/install-marker.py\" --install-route claude-plugins",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "author": {
    "name": "eugenelim",
    "email": "eugenelim@users.noreply.github.com"
  },
  "license": "Apache-2.0 OR MIT",
  "homepage": "https://github.com/eugenelim/agent-ready-repo",
  "repository": "https://github.com/eugenelim/agent-ready-repo",
  "keywords": [
    "github",
    "milestone",
    "brief",
    "intake",
    "receive-brief"
  ],
  "displayName": "GitHub"
}
