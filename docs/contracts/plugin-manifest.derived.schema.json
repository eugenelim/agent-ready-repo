{
  "type": "object",
  "required": ["name", "version", "description"],
  "additionalProperties": false,
  "properties": {
    "name": {"type": "string"},
    "version": {"type": "string"},
    "description": {"type": "string"},
    "skills": {
      "type": "array",
      "items": {"type": "string"}
    },
    "agents": {
      "type": "array",
      "items": {"type": "string"}
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string"},
        "email": {"type": "string"}
      }
    },
    "license": {"type": "string"},
    "homepage": {"type": "string"},
    "repository": {"type": "string"},
    "keywords": {
      "type": "array",
      "items": {"type": "string"}
    },
    "category": {"type": "string"},
    "displayName": {"type": "string"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {"type": "string"},
        "repo": {"type": "string"},
        "branch": {"type": "string"},
        "directory": {"type": "string"}
      }
    },
    "hooks": {
      "type": "object",
      "properties": {
        "SessionStart": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["command"],
            "properties": {
              "command": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
